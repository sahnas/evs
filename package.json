{
  "name": "evs",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "dev:backend": "pnpm --filter @evs/backend dev",
    "dev:frontend": "pnpm --filter @evs/frontend dev",
    "build": "pnpm -r build",
    "start": "pnpm --parallel -r start",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0"
  }
}